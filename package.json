{
  "name": "clubit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "node scripts/strip-dev-routes.mjs && next build && node scripts/check-no-dev-routes.mjs",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rls": "vitest run --config vitest.rls.config.ts",
    "test:e2e": "playwright test",
    "rotate-tokens:prod": "tsx scripts/rotate-existing-tokens.ts",
    "build:ios": "next build && npx cap sync ios",
    "build:ios:ci": "next build && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:sync": "npx cap sync ios",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@clerk/nextjs": "^7.2.7",
    "@stripe/stripe-js": "^9.3.1",
    "@supabase/supabase-js": "^2.105.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
